{
  "name": "prachyzaregistraci-prototype",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && vite build --ssr src/entry-server.tsx --outDir .ssr-dist && node scripts/prerender.mjs",
    "build:pages": "tsc -b && vite build --base /pzpapp/ && vite build --ssr src/entry-server.tsx --outDir .ssr-dist --base /pzpapp/ && node scripts/prerender.mjs",
    "typecheck": "tsc -b",
    "test:seo": "node scripts/test-seo.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^6.0.5"
  }
}
